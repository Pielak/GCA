{
  "name": "GCA External Project Validation (DeepSeek)",
  "description": "Receives external project questionnaire, analyzes with DeepSeek, returns gaps and recommendations",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "external-project",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "webhook_trigger",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [0, 300]
    },
    {
      "parameters": {
        "mode": "jsonTojsonata",
        "expression": "{\n  \"request_id\": $request_id,\n  \"request_number\": $request_number,\n  \"gp_email\": $gp_email,\n  \"questionnaire\": $questionnaire_data,\n  \"analysis_prompt\": $join([\n    \"Você é um especialista em análise técnica de arquitetura de software.\",\n    \"\",\n    \"Analise este questionário de projeto técnico e identifique:\",\n    \"1. GAPS: Informações ausentes ou incompletas\",\n    \"2. CONFLICTS: Contradições nas escolhas (ex: monolito + microserviços)\",\n    \"3. RISKS: Preocupações técnicas ou arquiteturais\",\n    \"4. RECOMMENDATIONS: Sugestões de melhorias\",\n    \"5. RISK_LEVEL: Nível de risco (baixo/médio/alto)\",\n    \"\",\n    \"Responda APENAS em JSON com as chaves: gaps, conflicts, risks, recommendations, risk_level\",\n    \"\",\n    \"Dados do Questionário:\",\n    JSON.stringify($questionnaire_data, null, 2)\n  ], \"\\n\")\n}"
      },
      "id": "prepare_prompt",
      "name": "Prepare DeepSeek Prompt",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [200, 300],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "url": "https://api.deepseek.com/v1/chat/completions",
        "method": "POST",
        "sendBody": true,
        "bodyContentType": "application/json",
        "body": "{\n  \"model\": \"deepseek-chat\",\n  \"max_tokens\": 2000,\n  \"temperature\": 0.7,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"{{ $json.analysis_prompt }}\"\n    }\n  ]\n}",
        "authentication": "generic",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headers": {\n  \"Authorization\": \"Bearer sk-767b8d1d04a640a8adc72ba1dc840290\",\n  \"Content-Type\": \"application/json\"\n}",
        "options": {}
      },
      "id": "deepseek_analysis",
      "name": "DeepSeek AI Analysis",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [400, 300],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "mode": "jsonTojsonata",
        "expression": "{\n  \"request_id\": $node['webhook_trigger'].json.request_id,\n  \"request_number\": $node['webhook_trigger'].json.request_number,\n  \"gp_email\": $node['webhook_trigger'].json.gp_email,\n  \"analysis\": $node['deepseek_analysis'].json.choices[0].message.content\n}"
      },
      "id": "parse_deepseek_response",
      "name": "Parse DeepSeek Response",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [500, 300],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "url": "http://backend:8000/api/v1/webhooks/external-project-result",
        "method": "POST",
        "sendBody": true,
        "bodyContentType": "application/json",
        "body": "{\n  \"request_id\": \"{{ $json.request_id }}\",\n  \"request_number\": \"{{ $json.request_number }}\",\n  \"gp_email\": \"{{ $json.gp_email }}\",\n  \"analysis\": {{ typeof $json.analysis === \"string\" ? JSON.parse($json.analysis) : $json.analysis }}\n}",
        "options": {}
      },
      "id": "callback_backend",
      "name": "Callback Backend",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [600, 300],
      "alwaysOutputData": true
    }
  ],
  "connections": {
    "webhook_trigger": {
      "main": [
        [
          {
            "node": "prepare_prompt",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "prepare_prompt": {
      "main": [
        [
          {
            "node": "deepseek_analysis",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "deepseek_analysis": {
      "main": [
        [
          {
            "node": "parse_deepseek_response",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "parse_deepseek_response": {
      "main": [
        [
          {
            "node": "callback_backend",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {}
}
