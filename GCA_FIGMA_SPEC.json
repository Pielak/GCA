{
  "meta": {
    "project": "GCA - Gestao de Codificacao Assistida",
    "version": "1.0",
    "date": "2026-04-07",
    "author": "Agilize TI",
    "description": "Especificacao completa de UI para geracao de telas no Figma Make. Cada pagina inclui layout, campos, validacoes, estados, transicoes e regras de negocio vinculadas."
  },

  "theme": {
    "mode": "dark",
    "colors": {
      "primary": "#7c3aed",
      "primaryDark": "#5b21b6",
      "primaryLight": "#ede9fe",
      "success": "#10b981",
      "warning": "#f59e0b",
      "error": "#ef4444",
      "info": "#3b82f6",
      "background": "#0a0a0f",
      "surface": "#0f172a",
      "surfaceLight": "#1e293b",
      "border": "#334155",
      "borderLight": "#475569",
      "textPrimary": "#f1f5f9",
      "textSecondary": "#94a3b8",
      "textMuted": "#64748b"
    },
    "fonts": {
      "sans": "Plus Jakarta Sans, system-ui, sans-serif",
      "mono": "JetBrains Mono, Fira Code, monospace"
    },
    "radii": { "sm": "6px", "md": "8px", "lg": "12px", "xl": "16px", "full": "9999px" },
    "spacing": { "xs": "4px", "sm": "8px", "md": "16px", "lg": "24px", "xl": "32px" }
  },

  "globalComponents": {
    "sidebar": {
      "id": "comp-sidebar",
      "width": { "expanded": "240px", "collapsed": "56px" },
      "background": "#0d0d18",
      "sections": [
        {
          "id": "sidebar-header",
          "content": { "logo": "Code2 icon", "title": "GCA", "subtitle": "Gestao de Codigo" },
          "toggleButton": { "action": "toggleSidebar", "icon": "ChevronLeft/Right" }
        },
        {
          "id": "sidebar-user",
          "content": { "avatar": "circle with user initial", "name": "currentUser.name", "role": "RoleBadge component" }
        },
        {
          "id": "sidebar-admin",
          "visibleIf": "currentUser.role === 'admin'",
          "label": "ADMINISTRACAO",
          "items": [
            { "label": "Dashboard Global", "icon": "LayoutDashboard", "route": "/admin", "rule": "RN-009" },
            { "label": "Projetos", "icon": "FolderOpen", "route": "/admin/projects", "rule": "RN-006" },
            { "label": "Usuarios", "icon": "Users", "route": "/admin/users", "rule": "RN-002" },
            { "label": "Auditoria Global", "icon": "ScrollText", "route": "/admin/audit", "rule": "RN-015" }
          ]
        },
        {
          "id": "sidebar-projects",
          "label": "MEUS PROJETOS",
          "collapsible": true,
          "items": "dynamic: user's projects list",
          "statusIndicators": {
            "active": { "color": "#10b981", "label": "Ativo" },
            "degraded": { "color": "#f59e0b", "label": "Degradado" },
            "provisioning": { "color": "#3b82f6", "pulsing": true, "label": "Provisionando" },
            "draft": { "color": "#64748b", "label": "Rascunho" }
          },
          "submenu": {
            "visibleIf": "currentPath starts with /projects/:id",
            "items": [
              { "label": "Dashboard", "icon": "Activity", "route": "/projects/:id" },
              { "label": "OCG", "icon": "Settings", "route": "/projects/:id/ocg" },
              { "label": "M4 - Ingestao", "icon": "FileText", "route": "/projects/:id/ingestion" },
              { "label": "M5 - Gatekeeper", "icon": "Shield", "route": "/projects/:id/gatekeeper" },
              { "label": "M6 - Merge Engine", "icon": "GitBranch", "route": "/projects/:id/merge" },
              { "label": "M7 - Arguidor", "icon": "Zap", "route": "/projects/:id/arguider" },
              { "label": "M8 - Code Gen", "icon": "Code2", "route": "/projects/:id/codegen" },
              { "label": "M9 - QA Readiness", "icon": "TestTube2", "route": "/projects/:id/qa" },
              { "label": "M10 - Legado", "icon": "History", "route": "/projects/:id/legacy" },
              { "label": "M11 - Roadmap", "icon": "Clock", "route": "/projects/:id/roadmap" },
              { "label": "M12 - Docs Viva", "icon": "BookOpen", "route": "/projects/:id/docs" }
            ]
          }
        },
        {
          "id": "sidebar-footer",
          "items": [
            { "label": "Sair", "icon": "LogOut", "action": "logout", "hoverColor": "#ef4444" }
          ]
        }
      ]
    },

    "header": {
      "id": "comp-header",
      "height": "64px",
      "background": "#0f172a",
      "borderBottom": "1px solid #1e293b",
      "left": [
        { "type": "button", "icon": "Menu", "action": "toggleSidebar", "visibleIf": "sidebar.collapsed" },
        { "type": "searchInput", "placeholder": "Buscar projetos, artefatos...", "width": "264px", "icon": "Search" }
      ],
      "right": [
        { "type": "notificationBell", "icon": "Bell", "badge": { "color": "#ef4444", "visibleIf": "notifications.count > 0" } },
        { "type": "userDropdown", "avatar": "initial circle", "name": "currentUser.name", "chevron": true }
      ]
    },

    "firstAccessModal": {
      "id": "comp-first-access-modal",
      "triggerCondition": "currentUser.first_access_completed === false",
      "rules": ["RN-001", "RN-002"],
      "overlay": { "background": "rgba(0,0,0,0.7)", "clickOutside": false },
      "modal": {
        "maxWidth": "500px",
        "background": "#1a1a2e",
        "borderRadius": "16px",
        "padding": "32px"
      },
      "header": {
        "icon": "Shield",
        "title": "Definir Senha Segura",
        "subtitle": "Por seguranca, voce precisa criar uma nova senha antes de continuar."
      },
      "warningBox": {
        "background": "#fef3c7",
        "border": "#f59e0b",
        "icon": "AlertTriangle",
        "text": "Esta acao e obrigatoria para garantir a seguranca da sua conta. Sua senha temporaria sera invalidada apos esta alteracao."
      },
      "fields": [
        {
          "id": "newPassword",
          "label": "Nova Senha (Obrigatoria)",
          "type": "password",
          "placeholder": "Minimo 10 caracteres",
          "toggleVisibility": true,
          "toggleIcon": { "show": "Eye", "hide": "EyeOff" },
          "validation": {
            "rules": [
              { "id": "minLength", "test": "length >= 10", "message": "Minimo 10 caracteres", "rule": "RN-001" },
              { "id": "uppercase", "test": "/[A-Z]/", "message": "Pelo menos 1 letra maiuscula", "rule": "RN-001" },
              { "id": "digit", "test": "/[0-9]/", "message": "Pelo menos 1 numero", "rule": "RN-001" },
              { "id": "special", "test": "/[!@#$%^&*()_+\\-=\\[\\]{};':\"\\\\|,.<>\\/?]/", "message": "Pelo menos 1 caractere especial", "rule": "RN-001" }
            ],
            "indicators": {
              "valid": { "icon": "CheckCircle2", "color": "#10b981" },
              "invalid": { "icon": "AlertCircle", "color": "#ef4444" }
            },
            "realtime": true
          }
        },
        {
          "id": "confirmPassword",
          "label": "Confirmar Senha",
          "type": "password",
          "placeholder": "Repita a nova senha",
          "toggleVisibility": true,
          "validation": {
            "rules": [
              { "id": "match", "test": "value === newPassword", "message": "As senhas devem ser identicas" }
            ]
          }
        }
      ],
      "submitButton": {
        "label": "Salvar e Continuar",
        "icon": "CheckCircle2",
        "disabledIf": "!newPassword || !passwordValid || !passwordsMatch",
        "loadingLabel": "Salvando...",
        "loadingIcon": "Loader2 (spinning)"
      },
      "apiCall": {
        "method": "POST",
        "endpoint": "/auth/change-first-password",
        "headers": { "Authorization": "Bearer ${token}" },
        "body": { "temporary_password": "props.temporaryPassword", "new_password": "fields.newPassword" },
        "onSuccess": { "action": "close modal", "callback": "props.onPasswordChanged()", "toast": "Senha alterada com sucesso!" },
        "onError": { "display": "errorBox", "style": { "background": "#7f1d1d", "border": "#ef4444" } }
      }
    },

    "statusBadge": {
      "variants": {
        "active": { "bg": "#064e3b", "text": "#34d399", "dot": "#10b981", "label": "Ativo" },
        "inactive": { "bg": "#1e293b", "text": "#94a3b8", "dot": "#64748b", "label": "Inativo" },
        "blocked": { "bg": "#7f1d1d", "text": "#fca5a5", "dot": "#ef4444", "label": "Bloqueado" },
        "pending": { "bg": "#78350f", "text": "#fcd34d", "dot": "#f59e0b", "label": "Pendente" },
        "provisioning": { "bg": "#1e3a5f", "text": "#93c5fd", "dot": "#3b82f6", "pulsing": true, "label": "Provisionando" }
      }
    },

    "roleBadge": {
      "variants": {
        "admin": { "bg": "#5b21b6", "text": "#c4b5fd", "label": "Admin" },
        "gp": { "bg": "#065f46", "text": "#6ee7b7", "label": "GP" },
        "tech_lead": { "bg": "#1e3a5f", "text": "#93c5fd", "label": "Tech Lead" },
        "dev_senior": { "bg": "#1e293b", "text": "#e2e8f0", "label": "Dev Senior" },
        "dev_pleno": { "bg": "#1e293b", "text": "#cbd5e1", "label": "Dev Pleno" },
        "qa": { "bg": "#78350f", "text": "#fcd34d", "label": "QA" },
        "compliance": { "bg": "#4c1d95", "text": "#c4b5fd", "label": "Compliance" },
        "viewer": { "bg": "#1e293b", "text": "#94a3b8", "label": "Viewer" }
      }
    }
  },

  "flows": {
    "firstAccessFlow": {
      "id": "flow-first-access",
      "name": "Primeiro Acesso (Convite -> Senha)",
      "rules": ["RN-001", "RN-002", "RN-005", "RN-008"],
      "steps": [
        {
          "step": 1,
          "actor": "Admin/GP",
          "action": "Envia convite por email",
          "page": null,
          "api": "POST /projects/:id/invite",
          "sideEffects": ["Email enviado com link + senha temporaria", "team_invites record criado com token (7 dias)"]
        },
        {
          "step": 2,
          "actor": "Usuario Convidado",
          "action": "Clica no link do email",
          "page": null,
          "api": "POST /projects/:id/accept-invite",
          "sideEffects": ["Usuario criado se nao existe", "first_access_completed = false", "project_member vinculado"]
        },
        {
          "step": 3,
          "actor": "Usuario Convidado",
          "action": "Faz login com senha temporaria",
          "page": "LoginPage",
          "fields": { "email": "email do convite", "password": "senha temporaria" },
          "api": "POST /auth/login",
          "response": { "access_token": "jwt", "refresh_token": "jwt", "user": { "first_access_completed": false } }
        },
        {
          "step": 4,
          "actor": "Sistema",
          "action": "Detecta first_access_completed === false, abre modal",
          "page": "AppLayout -> FirstAccessModal",
          "triggerCondition": "currentUser.first_access_completed === false",
          "modal": "firstAccessModal"
        },
        {
          "step": 5,
          "actor": "Usuario Convidado",
          "action": "Define nova senha com validacao em tempo real",
          "page": "FirstAccessModal",
          "fields": {
            "newPassword": { "validation": "10+ chars, upper, digit, special" },
            "confirmPassword": { "validation": "must match newPassword" }
          },
          "validationFeedback": "Icones CheckCircle2 (verde) e AlertCircle (vermelho) ao lado de cada regra"
        },
        {
          "step": 6,
          "actor": "Sistema",
          "action": "Salva nova senha, fecha modal",
          "api": "POST /auth/change-first-password",
          "sideEffects": ["first_access_completed = true", "password_hash atualizado", "modal fecha", "toast de sucesso"],
          "nextPage": "/dashboard"
        }
      ]
    },

    "passwordResetFlow": {
      "id": "flow-password-reset",
      "name": "Recuperacao de Senha",
      "rules": ["RN-001", "RN-003"],
      "steps": [
        {
          "step": 1,
          "actor": "Usuario",
          "action": "Acessa tela de reset",
          "page": "ResetPasswordPage (step: request)",
          "fields": { "email": { "type": "email", "required": true, "placeholder": "seu@email.com" } },
          "submitButton": { "label": "Enviar Link de Recuperacao", "icon": "Mail" }
        },
        {
          "step": 2,
          "actor": "Sistema",
          "action": "Envia email com token de reset (1 hora, uso unico)",
          "api": "POST /auth/reset-password",
          "sideEffects": ["reset_tokens record criado", "Email enviado com link contendo ?token=xyz"],
          "feedback": "Mensagem generica: 'Se o email existir, voce recebera um link' (seguranca)"
        },
        {
          "step": 3,
          "actor": "Usuario",
          "action": "Clica no link do email",
          "page": "ResetPasswordPage (step: verify)",
          "api": "POST /auth/verify-reset-token",
          "autoAdvance": true
        },
        {
          "step": 4,
          "actor": "Usuario",
          "action": "Define nova senha",
          "page": "ResetPasswordPage (step: confirm)",
          "fields": {
            "newPassword": { "validation": "same as firstAccess: 10+ chars, upper, digit, special" },
            "confirmPassword": { "validation": "must match" }
          },
          "submitButton": { "label": "Alterar Senha", "icon": "Lock" },
          "api": "POST /auth/reset-password-confirm",
          "onSuccess": "Redirect to /login after 2s with success toast"
        }
      ]
    },

    "projectCreationFlow": {
      "id": "flow-project-creation",
      "name": "Criacao e Aprovacao de Projeto",
      "rules": ["RN-006", "RN-007", "RN-009"],
      "steps": [
        {
          "step": 1,
          "actor": "GP",
          "action": "Solicita criacao de projeto",
          "page": "AdminProjectsPage (ou formulario dedicado)",
          "api": "POST /admin/projects",
          "fields": { "projectName": "text", "projectSlug": "text (auto-generated)", "description": "textarea" },
          "sideEffects": ["project_requests record com status PENDING"]
        },
        {
          "step": 2,
          "actor": "Admin",
          "action": "Visualiza solicitacao pendente",
          "page": "AdminProjectsPage",
          "ui": {
            "alertBox": { "icon": "Clock", "bg": "#1e3a5f", "text": "Existem X solicitacoes pendentes" },
            "requestCard": {
              "fields": ["projectName", "description", "requestedBy", "outputProfile", "requestedAt"],
              "actions": [
                { "label": "Rejeitar", "icon": "XCircle", "color": "#ef4444", "api": "POST /admin/projects/:id/reject" },
                { "label": "Aprovar e Liberar", "icon": "CheckCircle", "color": "#10b981", "api": "POST /admin/projects/:id/approve" }
              ]
            }
          }
        },
        {
          "step": 3,
          "actor": "Sistema",
          "action": "Provisiona schema PostgreSQL isolado",
          "sideEffects": ["Schema proj_{slug} criado", "Tabelas tenant criadas", "project.status = ACTIVE", "Senha inicial gerada para GP"],
          "nextStep": "Onboarding 5 etapas"
        },
        {
          "step": 4,
          "actor": "GP",
          "action": "Completa onboarding em 5 etapas",
          "steps": [
            { "etapa": 1, "nome": "Repositorio", "fields": ["provider (GitHub/GitLab/Bitbucket)", "repoUrl", "accessToken"], "validation": "Token verificado via API" },
            { "etapa": 2, "nome": "SMTP", "fields": ["smtpHost", "smtpPort", "smtpUser", "smtpPassword", "fromEmail"], "validation": "Email de teste enviado" },
            { "etapa": 3, "nome": "Equipe", "fields": ["email", "role"], "validation": "Convites enviados", "repeatable": true },
            { "etapa": 4, "nome": "Arquitetura", "fields": ["architecturePattern", "deploymentModel", "scalability"], "validation": "Analise n8n/Piloter" },
            { "etapa": 5, "nome": "Stack", "fields": ["language", "framework", "database", "frontendFramework"], "validation": "Onboarding completo" }
          ],
          "rule": "RN-007: Etapa seguinte so habilita apos conclusao da anterior"
        }
      ]
    },

    "questionnaireToCodeFlow": {
      "id": "flow-questionnaire-to-code",
      "name": "Questionario -> OCG -> Codigo",
      "rules": ["RN-010", "RN-011", "RN-012", "RN-013", "RN-014", "RN-015", "RN-016", "RN-017", "RN-018", "RN-019"],
      "steps": [
        {
          "step": 1,
          "actor": "GP",
          "action": "Preenche questionario de 49 perguntas",
          "page": "OCGPage (questionario)",
          "blocks": [
            { "bloco": "A.1", "perguntas": "Q1-Q6", "tema": "Info geral", "obrigatorio": true },
            { "bloco": "A.2", "perguntas": "Q7-Q14", "tema": "Projeto existente", "obrigatorio": "Q3 === Sim" },
            { "bloco": "A.3", "perguntas": "Q15-Q20", "tema": "Entrega e arquitetura", "obrigatorio": true },
            { "bloco": "A.4", "perguntas": "Q21-Q25", "tema": "Frontend", "obrigatorio": "Q21 === Sim" },
            { "bloco": "A.5", "perguntas": "Q26-Q30", "tema": "Backend", "obrigatorio": "Q26 === Sim" },
            { "bloco": "A.6", "perguntas": "Q31-Q38", "tema": "Dados e mensageria", "obrigatorio": true },
            { "bloco": "A.7", "perguntas": "Q39-Q44", "tema": "IA, seguranca, obs.", "obrigatorio": true },
            { "bloco": "A.8", "perguntas": "Q45-Q49", "tema": "Testes e entregaveis", "obrigatorio": true }
          ],
          "api": "POST /questionnaires/"
        },
        {
          "step": 2,
          "actor": "Sistema",
          "action": "Valida com 20+ regras, calcula score de aderencia",
          "rules": ["RN-011", "RN-012"],
          "outputs": {
            "approved": { "condition": "score >= 85", "status": "OK para ingestao", "nextStep": 3 },
            "pendente": { "condition": "score < 85, sem blockers", "status": "Pendente de ajustes", "action": "GP corrige e reenvia" },
            "inconsistente": { "condition": "tem blockers", "status": "Inconsistente - revisar", "action": "GP corrige campos destacados" }
          },
          "retornoA12": {
            "Q50": "Restricoes identificadas",
            "Q51": "Observacoes com acoes necessarias",
            "Q52": "Percentual respondido",
            "Q53": "Status do questionario",
            "Q54": "Agentes que validaram"
          }
        },
        {
          "step": 3,
          "actor": "Sistema (8 Agentes IA)",
          "action": "Pipeline OCG: Analyzer -> 7 Pilares (paralelo) -> Consolidator",
          "duration": "2-5 minutos",
          "page": "OCGPage (loading/progress)",
          "output": "OCG completo com scores, stack, findings, compliance, testes"
        },
        {
          "step": 4,
          "actor": "GP/Admin",
          "action": "Revisa OCG e aprova",
          "page": "GatekeeperPage",
          "ui": {
            "radarChart": "7 pilares com scores",
            "statusBadge": "READY / NEEDS_REVIEW / AT_RISK / BLOCKED",
            "findings": "Lista de achados criticos",
            "stackRecommendation": "Backend, Frontend, DB, Cache, Infra"
          },
          "blockingRule": "RN-015: P7 < 70 = BLOQUEADO, nao pode gerar codigo"
        },
        {
          "step": 5,
          "actor": "GP",
          "action": "Solicita geracao de codigo",
          "page": "CodeGeneratorPage",
          "fields": { "language": "dropdown", "architecture": "dropdown", "ocgId": "auto-filled" },
          "api": "POST /code-generation/project",
          "output": "Codigo gerado como artefato"
        },
        {
          "step": 6,
          "actor": "Sistema",
          "action": "Opcionalmente publica no GitHub",
          "api": ["POST /github/branches/create", "POST /github/commits/create", "POST /github/pullrequests/create"]
        }
      ]
    }
  },

  "pages": {
    "loginPage": {
      "id": "page-login",
      "route": "/login",
      "auth": false,
      "rules": ["RN-001"],
      "layout": {
        "type": "splitScreen",
        "left": {
          "width": "45%",
          "background": "gradient: #0d0d18 to #1a1a2e",
          "content": {
            "logo": { "icon": "Code2", "size": "48px", "color": "#7c3aed" },
            "title": "GCA",
            "subtitle": "Gestao de Codificacao Assistida",
            "features": [
              { "icon": "Shield", "text": "7 Pilares de Avaliacao" },
              { "icon": "Code2", "text": "Code Gen com IA" },
              { "icon": "TestTube2", "text": "QA Automatizado" },
              { "icon": "Database", "text": "Multi-tenant Isolado" }
            ]
          }
        },
        "right": {
          "width": "55%",
          "background": "#0f172a",
          "content": "loginForm"
        }
      },
      "form": {
        "id": "login-form",
        "fields": [
          {
            "id": "email",
            "label": "Email",
            "type": "email",
            "placeholder": "seu@email.com",
            "required": true,
            "validation": { "schema": "z.string().email('Email invalido')" }
          },
          {
            "id": "password",
            "label": "Senha",
            "type": "password",
            "placeholder": "Sua senha",
            "required": true,
            "toggleVisibility": true,
            "validation": { "schema": "z.string().min(6, 'Senha muito curta')" }
          }
        ],
        "submitButton": {
          "label": "Entrar",
          "fullWidth": true,
          "loadingLabel": "Autenticando...",
          "icon": "LogIn"
        },
        "links": [
          { "text": "Esqueci minha senha", "route": "/reset-password" }
        ]
      },
      "apiCall": {
        "method": "POST",
        "endpoint": "/auth/login",
        "body": { "email": "fields.email", "password": "fields.password" },
        "onSuccess": {
          "storeToken": "response.access_token",
          "storeUser": "response.user",
          "redirect": { "if": "user.first_access_completed === false", "then": "show FirstAccessModal", "else": "/dashboard" }
        },
        "onError": {
          "401": "Email ou senha incorretos",
          "403": "Conta bloqueada. Contate o administrador. (RN-004: 5 tentativas)"
        }
      },
      "transitions": {
        "onLoginSuccess_firstAccess": { "target": "firstAccessModal", "condition": "user.first_access_completed === false" },
        "onLoginSuccess_normal": { "target": "/dashboard", "condition": "user.first_access_completed === true" },
        "onForgotPassword": { "target": "/reset-password" }
      }
    },

    "resetPasswordPage": {
      "id": "page-reset-password",
      "route": "/reset-password",
      "auth": false,
      "rules": ["RN-001", "RN-003"],
      "stateMachine": {
        "initial": "request",
        "states": {
          "request": {
            "title": "Recuperar Senha",
            "subtitle": "Informe seu email para receber o link de recuperacao",
            "fields": [
              { "id": "email", "label": "Email cadastrado", "type": "email", "required": true }
            ],
            "submitButton": { "label": "Enviar Link de Recuperacao", "icon": "Mail" },
            "api": { "method": "POST", "endpoint": "/auth/reset-password", "body": { "email": "fields.email" } },
            "onSuccess": "Mensagem generica + auto-advance to verify (se token na URL)",
            "transitions": { "onSubmit": "request -> verify (se ?token na URL)" }
          },
          "verify": {
            "title": "Verificando Token...",
            "auto": true,
            "api": { "method": "POST", "endpoint": "/auth/verify-reset-token", "body": { "token": "url.searchParams.token" } },
            "onSuccess": "advance to confirm",
            "onError": { "message": "Token invalido ou expirado. Solicite um novo link.", "redirect": "request" }
          },
          "confirm": {
            "title": "Definir Nova Senha",
            "fields": [
              {
                "id": "newPassword",
                "label": "Nova Senha",
                "type": "password",
                "toggleVisibility": true,
                "validation": "same as firstAccessModal (10+ chars, upper, digit, special)",
                "realtimeIndicators": true
              },
              {
                "id": "confirmPassword",
                "label": "Confirmar Senha",
                "type": "password",
                "toggleVisibility": true,
                "validation": { "rules": [{ "test": "value === newPassword", "message": "Senhas nao conferem" }] }
              }
            ],
            "submitButton": { "label": "Alterar Senha", "icon": "Lock", "disabledIf": "!valid || !match" },
            "api": { "method": "POST", "endpoint": "/auth/reset-password-confirm", "body": { "token": "url.token", "new_password": "fields.newPassword" } },
            "onSuccess": { "toast": "Senha alterada com sucesso!", "redirect": "/login", "delay": "2000ms" }
          }
        }
      }
    },

    "adminDashboardPage": {
      "id": "page-admin-dashboard",
      "route": "/admin",
      "auth": true,
      "requiredRole": "admin",
      "rules": ["RN-009"],
      "sections": [
        {
          "id": "kpi-cards",
          "type": "grid",
          "columns": 4,
          "cards": [
            { "title": "Total de Projetos", "value": "projects.length", "icon": "FolderOpen", "color": "#7c3aed" },
            { "title": "Projetos Ativos", "value": "projects.filter(active).length", "icon": "Activity", "color": "#10b981" },
            { "title": "Degradados", "value": "projects.filter(degraded).length", "icon": "AlertTriangle", "color": "#f59e0b" },
            { "title": "Usuarios", "value": "users.filter(active).length", "subtitle": "X inativos", "icon": "Users", "color": "#3b82f6" }
          ]
        },
        {
          "id": "charts",
          "type": "grid",
          "columns": 2,
          "charts": [
            { "type": "pie", "title": "Distribuicao de Status", "data": "projects grouped by status" },
            { "type": "bar", "title": "Score Gatekeeper por Projeto", "data": "projects with gatekeeper scores" }
          ]
        },
        {
          "id": "alerts",
          "type": "list",
          "title": "Credenciais com Alerta",
          "items": "credentials with expired/suspected status"
        },
        {
          "id": "recentActivity",
          "type": "timeline",
          "title": "Atividade Recente",
          "maxItems": 5,
          "colorByLevel": { "critical": "#ef4444", "warning": "#f59e0b", "info": "#10b981" }
        }
      ]
    },

    "adminProjectsPage": {
      "id": "page-admin-projects",
      "route": "/admin/projects",
      "auth": true,
      "requiredRole": "admin",
      "rules": ["RN-006", "RN-009"],
      "sections": [
        {
          "id": "pending-requests",
          "type": "alertList",
          "title": "Solicitacoes Pendentes",
          "emptyState": "Nenhuma solicitacao pendente",
          "itemLayout": {
            "fields": ["projectName", "description", "requestedBy", "outputProfile", "requestedAt"],
            "actions": [
              { "label": "Rejeitar", "icon": "XCircle", "color": "#ef4444", "confirm": true, "confirmMessage": "Tem certeza que deseja rejeitar este projeto?", "api": "POST /admin/projects/:id/reject" },
              { "label": "Aprovar e Liberar", "icon": "CheckCircle", "color": "#10b981", "api": "POST /admin/projects/:id/approve" }
            ]
          }
        },
        {
          "id": "filters",
          "type": "filterBar",
          "fields": [
            { "id": "search", "type": "text", "placeholder": "Buscar por nome ou slug", "icon": "Search" },
            { "id": "status", "type": "select", "options": ["all", "active", "degraded", "provisioning", "draft", "suspended", "archived"] }
          ]
        },
        {
          "id": "projects-table",
          "type": "table",
          "columns": [
            { "header": "PROJETO", "fields": ["name", "slug"] },
            { "header": "STATUS", "component": "StatusBadge" },
            { "header": "OUTPUT", "field": "outputProfile" },
            { "header": "FASE", "field": "phase" },
            { "header": "GP", "fields": ["avatar", "name"] },
            { "header": "GATEKEEPER", "component": "progressBar + score" },
            { "header": "PENDENCIAS", "field": "pendingIssues" }
          ],
          "rowAction": { "click": "navigate to /projects/:id" }
        }
      ]
    },

    "adminUsersPage": {
      "id": "page-admin-users",
      "route": "/admin/users",
      "auth": true,
      "requiredRole": "admin",
      "rules": ["RN-002", "RN-004", "RN-009"],
      "sections": [
        {
          "id": "filters",
          "type": "filterBar",
          "fields": [
            { "id": "search", "type": "text", "placeholder": "Buscar por nome ou email" },
            { "id": "status", "type": "select", "options": ["all", "active", "inactive"] }
          ]
        },
        {
          "id": "users-table",
          "type": "table",
          "scope": "Apenas GPs (Gestores de Projeto)",
          "columns": [
            { "header": "GERENTE", "fields": ["avatar", "name", "email"] },
            { "header": "PROJETOS", "value": "X ativos, Y arquivados" },
            { "header": "STATUS", "component": "StatusBadge" },
            { "header": "ULTIMA ACAO", "fields": ["actionName", "actionDate"] },
            { "header": "DESDE", "field": "createdAt", "format": "dd/MM/yyyy" },
            { "header": "ACOES", "actions": [
              { "icon": "Eye", "tooltip": "Ver detalhes", "action": "openDetailModal" },
              { "icon": "Lock/Unlock", "tooltip": "Bloquear/Desbloquear", "action": "toggleBlock", "rule": "RN-004" },
              { "icon": "Zap", "tooltip": "Revogar acesso GP", "action": "revokeGP", "confirm": true }
            ]}
          ]
        },
        {
          "id": "detail-modal",
          "type": "modal",
          "maxWidth": "672px",
          "maxHeight": "80vh",
          "scrollable": true,
          "content": {
            "header": { "avatar": true, "name": true, "email": true, "role": "RoleBadge" },
            "sections": [
              { "title": "Projetos Gerenciados", "type": "list", "items": "user's projects with status" },
              { "title": "Historico de Acoes Criticas", "type": "timeline", "items": "audit log for user" }
            ]
          }
        }
      ]
    },

    "projectTeamPage": {
      "id": "page-project-team",
      "route": "/projects/:id/team",
      "auth": true,
      "rules": ["RN-005", "RN-008"],
      "sections": [
        {
          "id": "invite-form",
          "type": "form",
          "title": "Convidar Novo Membro",
          "icon": "UserPlus",
          "layout": "grid-3-cols",
          "fields": [
            {
              "id": "email",
              "label": "Email do Membro *",
              "type": "email",
              "placeholder": "dev@empresa.com",
              "required": true,
              "colSpan": 1
            },
            {
              "id": "role",
              "label": "Papel *",
              "type": "select",
              "default": "dev_pleno",
              "options": [
                { "value": "tech_lead", "label": "Tech Lead" },
                { "value": "dev_senior", "label": "Dev Senior" },
                { "value": "dev_pleno", "label": "Dev Pleno" },
                { "value": "qa", "label": "QA" },
                { "value": "compliance", "label": "Compliance" }
              ],
              "colSpan": 1
            },
            {
              "id": "submit",
              "type": "button",
              "label": "Convidar",
              "icon": "UserPlus",
              "disabledIf": "loading || !email",
              "loadingLabel": "Enviando...",
              "colSpan": 1,
              "alignSelf": "end"
            }
          ],
          "api": {
            "method": "POST",
            "endpoint": "/projects/:projectId/invite",
            "body": { "email": "fields.email", "role": "fields.role" },
            "onSuccess": { "toast": "Convite enviado com sucesso!", "clearForm": true, "reloadInvites": true },
            "onError": { "display": "inline error message" }
          }
        },
        {
          "id": "pending-invites",
          "type": "cardList",
          "title": "Convites Pendentes ({count})",
          "icon": "ClipboardList",
          "emptyState": { "icon": "CheckCircle", "message": "Nenhum convite pendente! Sua equipe esta toda integrada.", "bg": "#064e3b" },
          "cardLayout": "grid-4-cols",
          "cardFields": [
            { "field": "email", "subtitle": "Convidado em: {invitedAt}" },
            { "field": "role", "component": "RoleBadge" },
            { "field": "expiresAt", "label": "Expira em:", "format": "dd/MM/yyyy", "rule": "RN-008: 7 dias" },
            { "field": "status", "component": "StatusBadge", "value": "Pendente" }
          ]
        },
        {
          "id": "team-members",
          "type": "cardList",
          "title": "Membros da Equipe ({count})",
          "cardFields": [
            { "field": "avatar + name" },
            { "field": "role", "component": "RoleBadge" },
            { "field": "joinedAt", "label": "Desde" },
            { "field": "capabilities", "type": "tagList" }
          ]
        },
        {
          "id": "footer-tip",
          "type": "infoBox",
          "icon": "Lightbulb",
          "text": "Os convites expiram em 7 dias. Os membros receberao um email com um link para aceitar o convite e configurar sua senha na primeira vez."
        }
      ]
    }
  },

  "validationRules": {
    "RN-001": {
      "id": "RN-001",
      "name": "Politica de Senha",
      "appliesTo": ["firstAccessModal", "resetPasswordPage", "changePasswordForm"],
      "rules": [
        { "field": "password", "test": "length >= 10", "message": "Minimo 10 caracteres" },
        { "field": "password", "test": "/[A-Z]/", "message": "Pelo menos 1 letra maiuscula" },
        { "field": "password", "test": "/[0-9]/", "message": "Pelo menos 1 numero" },
        { "field": "password", "test": "/[!@#$%^&*()_+\\-=\\[\\]{};':\"\\\\|,.<>\\/?]/", "message": "Pelo menos 1 caractere especial" }
      ],
      "uiIndicators": {
        "valid": { "icon": "CheckCircle2", "color": "#10b981" },
        "invalid": { "icon": "AlertCircle", "color": "#ef4444" },
        "realtime": true
      }
    },
    "RN-002": {
      "id": "RN-002",
      "name": "Primeiro Acesso Obrigatorio",
      "trigger": "user.first_access_completed === false",
      "action": "Exibir FirstAccessModal. Bloquear navegacao ate troca de senha.",
      "appliesTo": ["AppLayout"]
    },
    "RN-003": {
      "id": "RN-003",
      "name": "Token de Reset",
      "rules": ["Expira em 1 hora", "Uso unico (single-use)", "Token de 32 bytes (secure random)"],
      "appliesTo": ["resetPasswordPage"]
    },
    "RN-004": {
      "id": "RN-004",
      "name": "Bloqueio por Tentativas",
      "trigger": "5 tentativas falhas consecutivas",
      "action": "Conta bloqueada. Mensagem: 'Conta bloqueada. Contate o administrador.'",
      "desbloqueio": "Manual pelo admin em AdminUsersPage",
      "appliesTo": ["loginPage"]
    },
    "RN-008": {
      "id": "RN-008",
      "name": "Expiracao de Convites",
      "rules": ["Token expira em 7 dias", "Token de 32 bytes", "Email obrigatorio"],
      "appliesTo": ["projectTeamPage"]
    },
    "RN-011": {
      "id": "RN-011",
      "name": "Score de Aderencia",
      "formula": "100 - (conflitos x 5) - (gaps x 10) - (incompatibilidades x 5)",
      "threshold": 85,
      "appliesTo": ["questionnaireAnalysis"]
    },
    "RN-015": {
      "id": "RN-015",
      "name": "Bloqueio P7 Seguranca",
      "trigger": "p7_security_score < 70",
      "action": "Artefato BLOQUEADO. Geracao de codigo impedida. Badge vermelho 'BLOCKED'.",
      "appliesTo": ["gatekeeperPage", "codeGeneratorPage"]
    }
  }
}
