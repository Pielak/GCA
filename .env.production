# ====== PRODUCTION CONFIGURATION ======
ENVIRONMENT=production
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://postgres:gca_secure_password@gca-postgres:5432/gca
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# JWT
SECRET_KEY=change_this_to_random_32_chars_minimum_for_production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SMTP
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASSWORD=seu-app-password
SMTP_FROM_EMAIL=noreply@gca.seu-dominio.com

# IA Provider
IA_PROVIDER=anthropic
IA_API_KEY=sk-ant-xxxxxxxxxxxxx
IA_MODEL=claude-opus-4-1

# Redis
REDIS_URL=redis://gca-redis:6379/0
REDIS_PASSWORD=change_this_too

# Frontend
VITE_API_BASE_URL=https://gca.seu-dominio.com/api/v1

# Cloudflare
CLOUDFLARE_DOMAIN=gca.seu-dominio.com

# Security
ALLOW_ORIGINS=["https://gca.seu-dominio.com"]
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Logging
LOG_LEVEL=INFO
