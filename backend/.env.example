# GCA Environment Configuration
# Copy this to .env and fill in your actual values

# App Settings
APP_NAME="GCA - Gerenciador Central de Arquiteturas"
APP_VERSION="0.1.0"
APP_ENV="development"
APP_SECRET_KEY="your-secret-key-generated"
DEBUG=False
HOST=0.0.0.0
PORT=8000
APP_HOST=0.0.0.0
APP_PORT=8000
API_PREFIX="/api/v1"
FRONTEND_URL="http://localhost:5173"

# PostgreSQL
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432
POSTGRES_DB="gca"
POSTGRES_USER="gca"
POSTGRES_PASSWORD="gca_secret"
DATABASE_URL="postgresql+asyncpg://gca:gca_secret@localhost:5432/gca"
DATABASE_BACKUP_URL="postgresql+asyncpg://gca:gca_secret@localhost:5432/gca"
DATABASE_ECHO=False
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_PRE_PING=True

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_URL="redis://localhost:6379/0"
REDIS_DECODE_RESPONSES=True

# Kafka
KAFKA_BOOTSTRAP_SERVERS="localhost:9092"
KAFKA_TOPIC_CODEGEN="gca.codegen.jobs"
KAFKA_TOPIC_LEGACY="gca.legacy.analysis"
KAFKA_TOPIC_ARTIFACT="gca.artifact.ingest"
KAFKA_TOPIC_GATEKEEPER="gca.gatekeeper.evaluate"

# Admin Seed (primeiro boot)
ADMIN_EMAIL="admin@example.com"
ADMIN_TEMP_PASSWORD="ChangeMe@123"

# JWT RS256 — gere com: openssl genrsa -out private.pem 2048
JWT_PRIVATE_KEY_PATH="/app/certs/private.pem"
JWT_PUBLIC_KEY_PATH="/app/certs/public.pem"
JWT_ALGORITHM="RS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
SESSION_INACTIVITY_HOURS=8

# Legacy JWT (HS256)
SECRET_KEY="your-secret-key-generated"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
ENCRYPTION_KEY="your-encryption-key-base64"

# Password Requirements
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=True
PASSWORD_REQUIRE_LOWERCASE=True
PASSWORD_REQUIRE_DIGITS=True
PASSWORD_REQUIRE_SYMBOLS=True

# SMTP (Email Notifications)
SMTP_ENABLED=True
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-specific-password"
SMTP_FROM_EMAIL="your-email@gmail.com"
SMTP_FROM_NAME="GCA - Gerenciador Central de Arquiteturas"

# GitHub Integration
GITHUB_TOKEN="your-github-classic-token-here"
GITHUB_REPO_URL="https://github.com/your-org/gca.git"
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitLab Integration
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# IA Providers
ANTHROPIC_API_KEY="your-anthropic-api-key-here"
OPENAI_API_KEY="your-openai-api-key-here"
GEMINI_API_KEY="your-gemini-api-key-here"
DEEPSEEK_API_KEY="your-deepseek-api-key-here"
GROK_API_KEY="your-grok-api-key-here"
DEFAULT_AI_PROVIDER="grok"
DEFAULT_AI_MODEL="grok-3-mini"

# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Microsoft Teams
TEAMS_BOT_ID=
TEAMS_BOT_PASSWORD=

# Storage
STORAGE_TYPE="local"
STORAGE_PATH="/tmp/gca-storage"
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Docker
DOCKER_ENABLED=False
DOCKER_HOST="unix:///var/run/docker.sock"
DOCKER_EXECUTOR_IMAGE="gca-executor:latest"

# Kafka
KAFKA_ENABLED=False
KAFKA_BOOTSTRAP_SERVERS="localhost:9092"
KAFKA_GROUP_ID="gca"

# Limits
MAX_UPLOAD_SIZE_MB=100
MAX_ARTIFACT_TEXT_LENGTH=1000000
ARTIFACT_EXTRACTION_TIMEOUT=30

# Audit
AUDIT_LOG_RETENTION_DAYS=365
AUDIT_LOG_BATCH_SIZE=100

# Logging
LOG_LEVEL="INFO"
LOG_FORMAT="json"

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]
