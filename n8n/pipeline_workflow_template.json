{
  "name": "GCA Pipeline - CodeGen to QA",
  "nodes": [
    {
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "position": [250, 300],
      "parameters": {
        "httpMethod": "POST",
        "path": "gca-pipeline",
        "responseMode": "onReceived"
      }
    },
    {
      "name": "Generate Code",
      "type": "n8n-nodes-base.httpRequest",
      "position": [500, 300],
      "parameters": {
        "method": "POST",
        "url": "=http://gca-backend:8000/api/v1/projects/{{$json.project_id}}/backlog/{{$json.backlog_item_id}}/generate-code",
        "authentication": "genericCredentialType",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{"name": "Authorization", "value": "Bearer {{$json.token}}"}]
        }
      }
    },
    {
      "name": "Generate Tests",
      "type": "n8n-nodes-base.httpRequest",
      "position": [750, 300],
      "parameters": {
        "method": "POST",
        "url": "=http://gca-backend:8000/api/v1/projects/{{$json.project_id}}/backlog/{{$json.backlog_item_id}}/generate-tests",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{"name": "Authorization", "value": "Bearer {{$json.token}}"}]
        }
      }
    },
    {
      "name": "Run Tests (CI)",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1000, 300],
      "parameters": {
        "method": "POST",
        "url": "=http://gca-backend:8000/api/v1/projects/{{$json.project_id}}/backlog/{{$json.backlog_item_id}}/run-tests",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{"name": "Authorization", "value": "Bearer {{$json.token}}"}]
        }
      }
    },
    {
      "name": "Wait for CI",
      "type": "n8n-nodes-base.wait",
      "position": [1250, 300],
      "parameters": {
        "amount": 30,
        "unit": "seconds"
      }
    },
    {
      "name": "Check CI Status",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1500, 300],
      "parameters": {
        "method": "GET",
        "url": "=http://gca-backend:8000/api/v1/projects/{{$json.project_id}}/backlog/{{$json.backlog_item_id}}/test-status",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{"name": "Authorization", "value": "Bearer {{$json.token}}"}]
        }
      }
    },
    {
      "name": "CI Pass?",
      "type": "n8n-nodes-base.if",
      "position": [1750, 300],
      "parameters": {
        "conditions": {
          "string": [{"value1": "={{$json.conclusion}}", "value2": "success"}]
        }
      }
    },
    {
      "name": "Security Scan",
      "type": "n8n-nodes-base.httpRequest",
      "position": [2000, 200],
      "parameters": {
        "method": "POST",
        "url": "=http://gca-backend:8000/api/v1/projects/{{$json.project_id}}/backlog/{{$json.backlog_item_id}}/security-scan",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{"name": "Authorization", "value": "Bearer {{$json.token}}"}]
        }
      }
    },
    {
      "name": "Compliance Check",
      "type": "n8n-nodes-base.httpRequest",
      "position": [2250, 200],
      "parameters": {
        "method": "POST",
        "url": "=http://gca-backend:8000/api/v1/projects/{{$json.project_id}}/backlog/{{$json.backlog_item_id}}/compliance-check",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{"name": "Authorization", "value": "Bearer {{$json.token}}"}]
        }
      }
    },
    {
      "name": "Notify QA",
      "type": "n8n-nodes-base.httpRequest",
      "position": [2500, 200],
      "parameters": {
        "method": "POST",
        "url": "={{$json.notification_webhook}}",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {"name": "text", "value": "=Codigo pronto para review: {{$json.item_title}} - Aguardando aprovacao QA"}
          ]
        }
      }
    }
  ],
  "connections": {
    "Webhook Trigger": {"main": [[{"node": "Generate Code", "type": "main", "index": 0}]]},
    "Generate Code": {"main": [[{"node": "Generate Tests", "type": "main", "index": 0}]]},
    "Generate Tests": {"main": [[{"node": "Run Tests (CI)", "type": "main", "index": 0}]]},
    "Run Tests (CI)": {"main": [[{"node": "Wait for CI", "type": "main", "index": 0}]]},
    "Wait for CI": {"main": [[{"node": "Check CI Status", "type": "main", "index": 0}]]},
    "Check CI Status": {"main": [[{"node": "CI Pass?", "type": "main", "index": 0}]]},
    "CI Pass?": {"main": [[{"node": "Security Scan", "type": "main", "index": 0}]]},
    "Security Scan": {"main": [[{"node": "Compliance Check", "type": "main", "index": 0}]]},
    "Compliance Check": {"main": [[{"node": "Notify QA", "type": "main", "index": 0}]]}
  }
}
